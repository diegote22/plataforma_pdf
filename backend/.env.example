# ---- Servidor ----
PORT=3000
NODE_ENV=development
# URL del frontend, para CORS (separar con coma si hay varias)
CORS_ORIGIN=http://localhost:5173

# ---- Supabase ----
# Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SERVICE ROLE key: SOLO backend. Ignora RLS. NUNCA exponer al frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Nombre del bucket de Storage donde viven los archivos de los materiales
SUPABASE_STORAGE_BUCKET=materials

# ---- Mercado Pago ----
# Credenciales de produccion/test del vendedor
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx
# Secreto de firma del webhook (MP Dashboard > Tus integraciones > Webhooks)
MP_WEBHOOK_SECRET=
# Moneda ISO (ARS, MXN, CLP, COP, etc.)
MP_CURRENCY=ARS
# URL publica del backend para recibir el webhook de MP
MP_WEBHOOK_URL=https://tu-backend.up.railway.app/api/webhooks/mercadopago
# A donde vuelve el comprador tras pagar (frontend)
MP_BACK_URL_SUCCESS=http://localhost:5173/pago/exito
MP_BACK_URL_FAILURE=http://localhost:5173/pago/error
MP_BACK_URL_PENDING=http://localhost:5173/pago/pendiente
